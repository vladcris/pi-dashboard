@using pi_dashboard.Models

<div class="tui-panel">
    <div class="tui-panel-title">─ MEMORY USAGE ─</div>

    <div class="tui-row">
        <span>
            <span class="tui-dot @TuiStyle.DotColor(Memory.UsagePercent)"></span>
            Memory: @FormatMB(Memory.UsedKB) / @FormatMB(Memory.TotalKB)
        </span>
        <span class="@TuiStyle.TextColor(Memory.UsagePercent)">@Memory.UsagePercent%</span>
    </div>
    <div class="tui-progress">
        <div class="tui-progress-fill @TuiStyle.BarClass(Memory.UsagePercent)" style="width: @Memory.UsagePercent%"></div>
    </div>

    <div class="tui-section-header">Memory Breakdown</div>

    <table class="tui-table">
        <thead>
            <tr>
                <th>Type</th>
                <th>Usage</th>
                <th style="text-align:right">Size</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td class="tui-muted">RAM Used</td>
                <td class="@TuiStyle.TextColor(Memory.UsagePercent)">@Memory.UsagePercent%</td>
                <td style="text-align:right">@FormatMB(Memory.UsedKB)</td>
            </tr>
            @if (Memory.SwapTotalKB > 0)
            {
                var swapPct = Math.Round((double)Memory.SwapUsedKB / Memory.SwapTotalKB * 100, 1);
                <tr>
                    <td class="tui-muted">Swap Used</td>
                    <td class="@TuiStyle.TextColor(swapPct)">@swapPct%</td>
                    <td style="text-align:right">@FormatMB(Memory.SwapUsedKB)</td>
                </tr>
            }
            <tr>
                <td class="tui-muted">Cache</td>
                <td></td>
                <td style="text-align:right">@FormatMB(Memory.CachedKB)</td>
            </tr>
            <tr>
                <td class="tui-muted">Available</td>
                <td class="@TuiStyle.TextColor(Memory.UsagePercent)">@(Math.Round(100 - Memory.UsagePercent, 0))%</td>
                <td style="text-align:right">@FormatMB(Memory.AvailableKB)</td>
            </tr>
        </tbody>
    </table>
</div>

@code {
    [Parameter, EditorRequired]
    public MemoryMetrics Memory { get; set; } = default!;

    private static string FormatMB(long kb) => $"{kb / 1024:N0}MB";
}
