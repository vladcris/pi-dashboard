@using pi_dashboard.Models

<div class="tui-panel">
    <div class="tui-panel-title">─ CPU USAGE ─</div>

    <div class="tui-row">
        <span>
            <span class="tui-dot @TuiStyle.DotColor(Cpu.TotalUsagePercent, high: 90)"></span>
            Load: @Cpu.LoadAverage1Min / @Cpu.CoreUsagePercents.Length cores
        </span>
        <span class="@TuiStyle.TextColor(Cpu.TotalUsagePercent, high: 90)">@Cpu.TotalUsagePercent%</span>
    </div>
    <div class="tui-progress">
        <div class="tui-progress-fill @TuiStyle.BarClass(Cpu.TotalUsagePercent, high: 90)" style="width: @Cpu.TotalUsagePercent%"></div>
    </div>

    <div class="tui-metric-sub">Load Average: @Cpu.LoadAverage1Min, @Cpu.LoadAverage5Min, @Cpu.LoadAverage15Min</div>

    <div class="tui-section-header">Per-Core</div>

    @for (int i = 0; i < Cpu.CoreUsagePercents.Length; i++)
    {
        var usage = Cpu.CoreUsagePercents[i];
        <div class="tui-row" style="font-size: 0.75rem;">
            <span class="tui-muted">Core @i</span>
            <span class="@TuiStyle.TextColor(usage, high: 90)">@usage%</span>
        </div>
        <div class="tui-progress slim">
            <div class="tui-progress-fill @TuiStyle.BarClass(usage, high: 90)" style="width: @usage%"></div>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public CpuMetrics Cpu { get; set; } = default!;

}
