@using pi_dashboard.Models

<div class="tui-panel">
    <div class="tui-panel-title">─ PROCESSES ─</div>

    <div class="tui-panel-scroll">
        <table class="tui-table">
            <thead>
                <tr>
                    <th>PID</th>
                    <th>Name</th>
                    <th style="text-align:right">CPU %</th>
                    <th style="text-align:right">Memory</th>
                    <th>State</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var proc in Processes)
                {
                    <tr>
                        <td class="tui-muted">@proc.Pid</td>
                        <td>@proc.Name</td>
                        <td class="@CpuColor(proc.CpuPercent)" style="text-align:right">@proc.CpuPercent</td>
                        <td class="tui-muted" style="text-align:right">@FormatMemory(proc.MemoryKB)</td>
                        <td class="tui-muted">@StateLabel(proc.State)</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public List<ProcessInfo> Processes { get; set; } = default!;

    private static string FormatMemory(long kb) => kb switch
    {
        >= 1048576 => $"{kb / 1048576.0:F1}GB",
        >= 1024    => $"{kb / 1024.0:F1}MB",
        _          => $"{kb}KB"
    };

    private static string StateLabel(string state) => state switch
    {
        "R" => "Running",
        "S" => "Sleeping",
        "D" => "Disk Wait",
        "Z" => "Zombie",
        "T" => "Stopped",
        "I" => "Idle",
        _   => state
    };

    private static string CpuColor(double p) => p >= 50 ? "tui-crit" : p >= 20 ? "tui-warn" : "";
}
