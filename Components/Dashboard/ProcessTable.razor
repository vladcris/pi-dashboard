@using pi_dashboard.Models

<div class="card">
    <div class="card-body">
        <h5 class="card-title">Top Processes</h5>
        <div class="table-responsive">
            <table class="table table-sm table-striped mb-0">
                <thead>
                    <tr>
                        <th>PID</th>
                        <th>Name</th>
                        <th class="text-end">CPU %</th>
                        <th class="text-end">Memory</th>
                        <th>State</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var proc in Processes)
                    {
                        <tr>
                            <td>@proc.Pid</td>
                            <td>@proc.Name</td>
                            <td class="text-end">@proc.CpuPercent</td>
                            <td class="text-end">@FormatMemory(proc.MemoryKB)</td>
                            <td>@GetStateLabel(proc.State)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public List<ProcessInfo> Processes { get; set; } = default!;

    private static string FormatMemory(long kb) => kb switch
    {
        >= 1048576 => $"{kb / 1048576.0:F1} GB",
        >= 1024 => $"{kb / 1024.0:F1} MB",
        _ => $"{kb} KB"
    };

    private static string GetStateLabel(string state) => state switch
    {
        "R" => "Running",
        "S" => "Sleeping",
        "D" => "Disk Wait",
        "Z" => "Zombie",
        "T" => "Stopped",
        "I" => "Idle",
        _ => state
    };
}
