@page "/"
@rendermode InteractiveServer
@using pi_dashboard.Models
@using pi_dashboard.Services
@using pi_dashboard.Components.Dashboard
@inject MetricsStore Store
@implements IDisposable

<PageTitle>Pi Dashboard</PageTitle>

@if (Store.Latest is null)
{
    <div class="tui-loading">[ CONNECTING... ]</div>
}
else
{
    var snapshot = Store.Latest;
    <div class="tui-grid">
        <AlertsCard Snapshot="snapshot" />
        <CpuCard Cpu="snapshot.Cpu" />
        <MemoryCard Memory="snapshot.Memory" />
        <DiskCard Disk="snapshot.Disk" />
        <SystemInfoCard SystemInfo="snapshot.System" Voltage="snapshot.Voltage" Temperature="snapshot.Temperature" />
        <ProcessTable Processes="snapshot.TopProcesses" />
    </div>
}

@code {
    protected override void OnInitialized()
    {
        Store.OnMetricsUpdated += OnMetricsUpdated;
    }

    private async void OnMetricsUpdated()
    {
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Store.OnMetricsUpdated -= OnMetricsUpdated;
    }
}
